! ============================================
! FRR Configuration for {{ hostname }}
! AS {{ asn }} | Role: {{ role }}
! Generated by Ansible/Jinja2 automation
! ============================================

configure terminal

! --- Loopback ---
interface lo
 ip address {{ loopback }}/32
exit

! --- Physical Interfaces ---
{% for iface, addr in interfaces.items() %}
interface {{ iface }}
 ip address {{ addr }}
exit
{% endfor %}

{% if ospf_networks is defined %}
! --- OSPF ---
router ospf
 ospf router-id {{ loopback }}
{% for net in ospf_networks %}
 network {{ net }}
{% endfor %}
exit
{% endif %}

! --- BGP ---
router bgp {{ asn }}
 bgp router-id {{ loopback }}
 no bgp ebgp-requires-policy
{% for n in bgp.neighbors %}
 neighbor {{ n.ip }} remote-as {{ n.remote_as }}
{% if n.update_source is defined %}
 neighbor {{ n.ip }} update-source {{ n.update_source }}
{% endif %}
{% if n.password is defined %}
 neighbor {{ n.ip }} password {{ n.password }}
{% endif %}
{% endfor %}
 address-family ipv4 unicast
{% for net in bgp.networks %}
  network {{ net }}
{% endfor %}
{% for n in bgp.neighbors %}
{% if n.next_hop_self is defined and n.next_hop_self %}
  neighbor {{ n.ip }} next-hop-self
{% endif %}
{% endfor %}
{% if prefix_lists is defined %}
{% for pl in prefix_lists %}
  neighbor {{ pl.neighbor }} prefix-list {{ pl.name }} {{ pl.direction }}
{% endfor %}
{% endif %}
 exit-address-family
exit

{% if prefix_lists is defined %}
! --- Prefix Lists ---
{% for pl in prefix_lists %}
{% for entry in pl.entries %}
ip prefix-list {{ pl.name }} {{ entry }}
{% endfor %}
{% endfor %}
{% endif %}

! --- Static Routes ---
{% for net in bgp.networks %}
ip route {{ net }} Null0
{% endfor %}
{% if static_routes is defined %}
{% for route in static_routes %}
ip route {{ route }}
{% endfor %}
{% endif %}

end
write memory
